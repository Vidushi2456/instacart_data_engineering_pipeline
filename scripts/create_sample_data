import pandas as pd
import os

DOWNLOADS_PATH = r"C:\Users\DELL\Downloads\dataset"
OUTPUT_PATH = r"C:\Users\DELL\OneDrive\Desktop\instacart_data_engineering_pipeline\data"

SAMPLE_SIZE = 5000

def create_consistent_sample():
    print("Creating consistent sample...")

    # Load full orders
    orders = pd.read_csv(os.path.join(DOWNLOADS_PATH, "orders.csv"))

    # Sample orders
    orders_sample = orders.sample(SAMPLE_SIZE, random_state=42)

    # Load full order_products
    order_products = pd.read_csv(os.path.join(DOWNLOADS_PATH, "order_products__prior.csv"))

    # Filter order_products based on sampled orders
    order_products_sample = order_products[
        order_products["order_id"].isin(orders_sample["order_id"])
    ]

    # Load products
    products = pd.read_csv(os.path.join(DOWNLOADS_PATH, "products.csv"))

    # Filter products based on order_products
    products_sample = products[
        products["product_id"].isin(order_products_sample["product_id"])
    ]

    # Save files
    orders_sample.to_csv(os.path.join(OUTPUT_PATH, "orders_sample.csv"), index=False)
    order_products_sample.to_csv(os.path.join(OUTPUT_PATH, "order_products_sample.csv"), index=False)
    products_sample.to_csv(os.path.join(OUTPUT_PATH, "products_sample.csv"), index=False)

    print("Consistent sample created successfully!")


if __name__ == "__main__":
    create_consistent_sample()